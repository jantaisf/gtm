          <a:prstGeom prst="rect"><a:avLst/></a:prstGeom>
          <a:solidFill><a:srgbClr val="2D3A6B"/></a:solidFill>
          <a:ln><a:noFill/></a:ln>
        </p:spPr>
        <p:txBody>
          <a:bodyPr wrap="square" lIns="182880" tIns="91440" rIns="182880" bIns="91440" rtlCol="0" anchor="ctr"/>
          <a:lstStyle/>
          <a:p>
            <a:pPr indent="0" marL="0"><a:buNone/></a:pPr>
            <a:r><a:rPr lang="en-US" sz="1100" b="1" dirty="0"><a:solidFill><a:srgbClr val="EF4444"/></a:solidFill></a:rPr><a:t xml:space="preserve">Q: “Why not just use NRR?” </a:t></a:r>
            <a:r><a:rPr lang="en-US" sz="1100" dirty="0"><a:solidFill><a:srgbClr val="CADCFC"/></a:solidFill></a:rPr><a:t>NRR is a lagging indicator — known only at renewal, 12 months later. cARR is observable today. cARR attainment predicts NRR; it doesn’t replace it.</a:t></a:r>
          </a:p>
        </p:txBody>
      </p:sp>

