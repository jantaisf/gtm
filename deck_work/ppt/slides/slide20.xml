      <p:sp>
        <p:nvSpPr><p:cNvPr id="10" name="Q1Bg"/><p:cNvSpPr/><p:nvPr/></p:nvSpPr>
        <p:spPr>
          <a:xfrm><a:off x="457200" y="1188720"/><a:ext cx="8229600" cy="548640"/></a:xfrm>
